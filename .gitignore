# ── Neuroimaging / data files ─────────────────────────────────────────────────
# Never commit real subject data — this is a hard safeguard
*.nii
*.nii.gz
*.mgh
*.mgz
*.img
*.hdr

# Confound / events files that may contain subject-level information
*_confounds_timeseries.tsv
*_events.tsv

# Allow bundled atlas NIfTI files that ship with the package
!braphin/atlases/*.nii
!braphin/atlases/*.nii.gz
!mrigraph/atlases/*.nii
!mrigraph/atlases/*.nii.gz

